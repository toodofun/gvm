```go
// internal/util/exec/executor_test.go
package exec

import (
    "context"
    "testing"

    "github.com/stretchr/testify/assert"
)

func TestParseCommand_RejectsShellMetacharacters(t *testing.T) {
    tests := []struct {
        name    string
        cmd     string
        wantErr bool
        errMsg  string
    }{
        {
            name:    "normal command",
            cmd:     "ls -la",
            wantErr: false,
        },
        {
            name:    "pipe character",
            cmd:     "ls | rm -rf /",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "command substitution",
            cmd:     "ls $(rm -rf /)",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "semicolon",
            cmd:     "ls; rm -rf /",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "backtick",
            cmd:     "ls `rm -rf /`",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "ampersand",
            cmd:     "ls & rm",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "dollar sign",
            cmd:     "ls $HOME",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "parentheses",
            cmd:     "ls (rm)",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "redirect",
            cmd:     "ls > file",
            wantErr: true,
            errMsg:  "dangerous character",
        },
        {
            name:    "backslash",
            cmd:     "ls \\",
            wantErr: true,
            errMsg:  "dangerous character",
        },
    }

    for _, tt := range tests {
        t.Run(tt.name, func(t *testing.T) {
            cmd, err := ParseCommand(tt.cmd)

            if tt.wantErr {
                assert.Error(t, err)
                assert.Contains(t, err.Error(), tt.errMsg)
                assert.Nil(t, cmd)
            } else {
                assert.NoError(t, err)
                assert.NotNil(t, cmd)
                assert.NotEmpty(t, cmd.Name)
            }
        })
    }
}
```

